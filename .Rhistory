data <- read.table("data/data/GSE60450_Lactation-GenewiseCounts.txt",
                   header = TRUE,
                   row.names = 1)

dim(data)
head(data)
class(data)
meta <- read.csv("data/data/metadata.csv")

head(meta)
colnames(data)
meta
condition <- factor(meta$condition)
length(condition)
ncol(data)
> length(condition)
ncol(data)
[1] 12
[1] 13
colnames(data)
meta
dim(meta)
data <- data[, -1]
ncol(data)
colnames(data) <- gsub("\\.", "-", colnames(data))
meta <- meta[match(colnames(data), meta$sample), ]
condition <- factor(meta$condition)
length(condition)
ncol(data)
library(DESeq2)

dds <- DESeqDataSetFromMatrix(
  countData = data,
  colData = data.frame(condition),
  design = ~ condition
)

dds <- DESeq(dds)
res <- results(dds)

head(res)
resSig <- res[which(res$pvalue < 0.05), ]
head(resSig)
nrow(resSig)
plot(res$log2FoldChange, -log10(res$pvalue),
     pch=20, main="Volcano Plot",
     xlab="Log2 Fold Change", ylab="-log10(p-value)")
abline(h=-log10(0.05), col="red")
vsd <- vst(dds)
plotPCA(vsd, intgroup="condition")
resOrdered <- res[order(res$pvalue), ]
head(resOrdered)
q
q()
